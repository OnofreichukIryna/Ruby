<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Теги проєктів</h1>
  <%= link_to "Додати тег", new_tag_path, class: "btn btn-success shadow-sm" %>
</div>

<div class="card shadow-sm border-0">
  <table class="table table-striped table-hover align-middle mb-0">
    <thead class="table-dark">
      <tr>
        <th class="ps-4">Візуалізація</th>
        <th>Назва в базі</th>
        <th class="text-end pe-4">Дії</th>
      </tr>
    </thead>
    <tbody>
      <% @tags.each do |tag| %>
        <tr>
          <td class="ps-4">
            <span class="badge rounded-pill bg-info text-dark fs-6">#<%= tag.name %></span>
          </td>
          <td class="text-muted"><%= tag.name %></td>
          <td class="text-end pe-4">
            <div class="btn-group shadow-sm">
              <%= link_to "Деталі", tag, class: "btn btn-sm btn-info text-white" %>
              <%= link_to "Редагувати", edit_tag_path(tag), class: "btn btn-sm btn-outline-primary" %>
              <%= button_to "Видалити", tag, method: :delete, data: { turbo_confirm: 'Видалити цей тег?' }, class: "btn btn-sm btn-danger" %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
