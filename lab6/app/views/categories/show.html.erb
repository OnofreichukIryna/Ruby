<div class="row mt-4">
  <div class="col-md-6 offset-md-3">
    <div class="card shadow-sm">
      <div class="card-header bg-dark text-white">
        <h2 class="mb-0">Деталі категорії</h2>
      </div>
      <div class="card-body text-center py-5">
        <p class="fs-4">
          <span class="text-muted">Назва:</span> <br>
          <strong><%= @category.name %></strong>
        </p>

        <div class="d-flex justify-content-center gap-2 mt-4">
          <%= link_to "Редагувати", edit_category_path(@category), class: "btn btn-primary" %>
          <%= link_to "До списку", categories_path, class: "btn btn-secondary" %>
          <%= button_to "Видалити", @category, method: :delete, data: { turbo_confirm: 'Ви впевнені?' }, class: "btn btn-danger" %>
        </div>
      </div>
    </div>
  </div>
</div>
