<div class="row mt-4">
  <div class="col-md-6 offset-md-3">
    <div class="card shadow-sm">
      <div class="card-header bg-dark text-white">
        <h2 class="mb-0">Деталі учасника</h2>
      </div>
      <div class="card-body py-4">
        <p class="fs-5">
          <strong class="text-muted">Ім'я:</strong> <%= @team_member.name %>
        </p>
        <p class="fs-5">
          <strong class="text-muted">Роль:</strong> <span class="badge bg-secondary"><%= @team_member.role %></span>
        </p>
        <p class="fs-5">
          <strong class="text-muted">ID Проєкту:</strong> <%= @team_member.project_id %>
        </p>

        <div class="d-flex justify-content-center gap-2 mt-4">
          <%= link_to "Редагувати", edit_team_member_path(@team_member), class: "btn btn-primary" %>
          <%= link_to "До списку", team_members_path, class: "btn btn-secondary" %>
          <%= button_to "Видалити", @team_member, method: :delete, data: { turbo_confirm: 'Ви впевнені?' }, class: "btn btn-danger" %>
        </div>
      </div>
    </div>
  </div>
</div>