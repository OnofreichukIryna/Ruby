<!DOCTYPE html>
<html>
  <head>
    <title>ProjectManager</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </head>

  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="container">
        <%= link_to "Менеджер проєктів", root_path, class: "navbar-brand" %>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav">
            <li class="nav-item">
              <%= link_to "Всі проєкти", projects_path, class: "nav-link" %>
            </li>
            <li class="nav-item">
              <%= link_to "Активні", in_progress_projects_path, class: "nav-link" %>
            </li>
            <li class="nav-item">
              <%= link_to "Дедлайн близько", deadline_soon_projects_path, class: "nav-link text-danger" %>
            </li>
            <li class="nav-item">
              <%= link_to "Категорії", categories_path, class: "nav-link" %>
            </li>
            <li class="nav-item">
              <%= link_to "Новий проєкт", new_project_path, class: "nav-link text-warning" %>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <main class="container mt-4">
      <% if notice %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
          <%= notice %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>